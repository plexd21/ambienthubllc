})

KeybindsTab:CreateSection("Rage Keybinds")

KeybindsTab:CreateKeybind({
    Name           = "Teleport Once",
    CurrentKeybind = "F4",
    HoldToInteract = false,
    Flag           = "KeyTeleportOnce",
    Callback       = function()
        teleportToTarget()
    end,
})

KeybindsTab:CreateKeybind({
    Name           = "Toggle Teleport Loop",
    CurrentKeybind = "F5",
    HoldToInteract = false,
    Flag           = "KeyTeleportLoop",
    Callback       = function()
        if not Settings.TeleportTarget or Settings.TeleportTarget == "" then
            Rayfield:Notify({ Title = "Rage", Content = "Select a player first.", Duration = 2 })
            return
        end
        Settings.TeleportLoopEnabled = not Settings.TeleportLoopEnabled
        if UIToggles["TeleportLoopToggle"] then UIToggles["TeleportLoopToggle"]:Set(Settings.TeleportLoopEnabled) end
        if Settings.TeleportLoopEnabled then
            startTeleportLoop()
        else
            stopTeleportLoop()
        end
        Rayfield:Notify({
            Title    = "Rage",
            Content  = "Teleport Loop " .. (Settings.TeleportLoopEnabled and "Enabled" or "Disabled"),
