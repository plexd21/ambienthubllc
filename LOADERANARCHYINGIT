-- ── Visuals Tab ───────────────────────────────────────
local VisualsTab = Window:CreateTab("Visuals", 4483362458)

VisualsTab:CreateSection("Highlight ESP")

local ESPToggle = VisualsTab:CreateToggle({
    Name         = "Enable Highlights",
    CurrentValue = false,
    Flag         = "ESPToggle",
    Callback     = function(v)
        Settings.ESPEnabled = v
        refreshAll()
    end,
})
UIToggles["ESPToggle"] = ESPToggle

VisualsTab:CreateColorPicker({
    Name     = "Fill Color",
    Color    = Color3.fromRGB(255, 0, 0),
    Flag     = "FillColor",
    Callback = function(v)
        Settings.FillColor = v
        refreshAll()
    end,
})

VisualsTab:CreateColorPicker({
    Name     = "Outline Color",
    Color    = Color3.fromRGB(255, 255, 255),
    Flag     = "OutlineColor",
    Callback = function(v)
        Settings.OutlineColor = v
        refreshAll()
    end,
})

VisualsTab:CreateSlider({
    Name         = "Fill Transparency",
    Range        = {0, 10},
    Increment    = 1,
    Suffix       = "",
    CurrentValue = 5,
    Flag         = "FillTransparency",
    Callback     = function(v)
        Settings.FillTransparency = v / 10
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            if player.Character then
                local h = player.Character:FindFirstChild("PlayerHighlight")
                if h then h.FillTransparency = Settings.FillTransparency end
            end
        end
    end,
})

VisualsTab:CreateSection("Name Tags")

local NamesToggle = VisualsTab:CreateToggle({
    Name         = "Show Names",
    CurrentValue = false,
    Flag         = "NamesToggle",
    Callback     = function(v)
        Settings.NamesEnabled = v
        if v then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then addNameBillboard(p, p.Character) end
            end
        else
            for _, p in ipairs(Players:GetPlayers()) do removeNameBillboard(p) end
        end
    end,
})
UIToggles["NamesToggle"] = NamesToggle

VisualsTab:CreateSlider({
    Name         = "Name Text Size",
    Range        = {8, 48},
    Increment    = 1,
    Suffix       = "px",
    CurrentValue = 14,
    Flag         = "NameSize",
    Callback     = function(v)
        Settings.NameSize = v
        for _, bg in pairs(nameBillboards) do
            if bg then
                local lbl = bg:FindFirstChildOfClass("TextLabel")
                if lbl then lbl.TextSize = v end
            end
        end
    end,
})

VisualsTab:CreateSection("Distance ESP")

local DistToggle = VisualsTab:CreateToggle({
    Name         = "Show Distance",
    CurrentValue = false,
    Flag         = "DistToggle",
    Callback     = function(v)
        Settings.DistanceEnabled = v
        if v then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then addDistanceBillboard(p, p.Character) end
            end
        else
            for _, p in ipairs(Players:GetPlayers()) do removeDistanceBillboard(p) end
        end
    end,
})
UIToggles["DistToggle"] = DistToggle

VisualsTab:CreateSlider({
    Name         = "Max Visible Distance",
    Range        = {0, 10000},
    Increment    = 100,
    Suffix       = "m",
    CurrentValue = 10000,
    Flag         = "MaxDistance",
    Callback     = function(v)
        Settings.MaxDistance = v
    end,
})

VisualsTab:CreateLabel("Players beyond max distance are hidden from all ESP.")

-- ── Rage Tab ──────────────────────────────────────────
local RageTab = Window:CreateTab("Rage", 4483362458)

RageTab:CreateSection("Teleport")

playerDropdown = RageTab:CreateDropdown({
    Name            = "Select Target Player",
    Options         = getPlayerNames(),
    CurrentOption   = {},
    MultipleOptions = false,
    Flag            = "TeleportTarget",
    Callback        = function(selected)
        local choice = type(selected) == "table" and selected[1] or selected
        Settings.TeleportTarget = choice or nil
    end,
})

RageTab:CreateButton({
    Name     = "Teleport Once",
    Callback = function()
        teleportToTarget()
    end,
})

local TeleportLoopToggle = RageTab:CreateToggle({
    Name         = "Teleport Loop",
    CurrentValue = false,
    Flag         = "TeleportLoopToggle",
    Callback     = function(v)
        Settings.TeleportLoopEnabled = v
        if v then
            if not Settings.TeleportTarget or Settings.TeleportTarget == "" then
                Rayfield:Notify({ Title = "Rage", Content = "Select a player first.", Duration = 2 })
                UIToggles["TeleportLoopToggle"]:Set(false)
                Settings.TeleportLoopEnabled = false
                return
            end
            startTeleportLoop()
        else
            stopTeleportLoop()
        end
    end,
})
UIToggles["TeleportLoopToggle"] = TeleportLoopToggle

RageTab:CreateSlider({
    Name         = "Loop Delay",
    Range        = {1, 10},
    Increment    = 1,
    Suffix       = "s",
    CurrentValue = 2,
    Flag         = "TeleportDelay",
    Callback     = function(v)
        Settings.TeleportDelay = v
    end,
})

RageTab:CreateLabel("Select a player from the dropdown, then teleport once or enable loop.")

