-- =====================
-- HIGHLIGHT
-- =====================

local function addHighlight(character)
    if not Settings.ESPEnabled then return end
    if character:FindFirstChild("PlayerHighlight") then return end
    local h = Instance.new("Highlight")
    h.Name                = "PlayerHighlight"
    h.FillColor           = Settings.FillColor
    h.OutlineColor        = Settings.OutlineColor
    h.FillTransparency    = Settings.FillTransparency
    h.OutlineTransparency = 0
    h.Parent              = character
end

local function removeHighlight(character)
    local h = character:FindFirstChild("PlayerHighlight")
    if h then h:Destroy() end
end

-- =====================
-- HITBOX EXPANDER
-- =====================

local function findPartInCharacter(character, groupName)
    local partList = PART_NAMES[groupName]
    if not partList then
        warn("[HitboxExpander] No part list for group:", groupName)
        return nil
    end

    -- Pass 1: direct child
    for _, partName in ipairs(partList) do
        local p = character:FindFirstChild(partName)
        if p and p:IsA("BasePart") then return p end
    end

    -- Pass 2: recursive FindFirstChild
    for _, partName in ipairs(partList) do
        local p = character:FindFirstChild(partName, true)
        if p and p:IsA("BasePart") then return p end
    end

    -- Pass 3: full descendant scan
    for _, desc in ipairs(character:GetDescendants()) do
        if desc:IsA("BasePart") then
            for _, partName in ipairs(partList) do
                if desc.Name == partName then return desc end
            end
        end
    end

    warn("[HitboxExpander] Could not find part for group:", groupName, "in", character.Name)
    return nil
end

local function addHitbox(player, character)
    if not Settings.HitboxEnabled then return end
    if not character then return end

    if hitboxData[player] then
        if hitboxData[player].box  and hitboxData[player].box.Parent  then hitboxData[player].box:Destroy()  end
        if hitboxData[player].part and hitboxData[player].part.Parent then hitboxData[player].part:Destroy() end
        hitboxData[player] = nil
    end

    local realPart = findPartInCharacter(character, Settings.HitboxTargetPart)
    if not realPart then
        warn("[HitboxExpander] Skipping hitbox for", player.Name, "- part not found:", Settings.HitboxTargetPart)
        return
    end

    local ok, err = pcall(function()
        local fakePart = Instance.new("Part")
        fakePart.Name         = "ESPHitboxPart"
        fakePart.Anchored     = false
        fakePart.CanCollide   = false
        fakePart.Transparency = 1
        fakePart.Size         = realPart.Size * Settings.HitboxScale
        fakePart.CFrame       = realPart.CFrame
        fakePart.Parent       = character

        local weld = Instance.new("WeldConstraint")
        weld.Part0  = realPart
        weld.Part1  = fakePart
        weld.Parent = fakePart

        local box = Instance.new("SelectionBox")
        box.Name                = "ESPHitbox"
        box.Adornee             = fakePart
        box.Color3              = Settings.HitboxColor
        box.LineThickness       = 0.05
        box.SurfaceTransparency = 0.7
        box.SurfaceColor3       = Settings.HitboxColor
        box.Parent              = character

        hitboxData[player] = { box = box, part = fakePart }
    end)

    if not ok then
        warn("[HitboxExpander] Error creating hitbox for", player.Name, ":", err)
    end
end

local function removeHitbox(player)
    if not hitboxData[player] then return end
    if hitboxData[player].box  and hitboxData[player].box.Parent  then hitboxData[player].box:Destroy()  end
    if hitboxData[player].part and hitboxData[player].part.Parent then hitboxData[player].part:Destroy() end
    hitboxData[player] = nil
end

local function refreshHitboxes()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if player.Character then
            removeHitbox(player)
            if Settings.HitboxEnabled then
                addHitbox(player, player.Character)
            end
        end
    end
end

-- =====================
-- NAME BILLBOARD
-- =====================

local function addNameBillboard(player, character)
    if not Settings.NamesEnabled then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if nameBillboards[player] then nameBillboards[player]:Destroy() end

    local bg = Instance.new("BillboardGui")
    bg.Name        = "ESPName"
    bg.Adornee     = hrp
    bg.Size        = UDim2.new(0, 200, 0, 30)
    bg.StudsOffset = Vector3.new(0, 3, 0)
    bg.AlwaysOnTop = true
    bg.Parent      = hrp

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size                   = UDim2.new(1, 0, 1, 0)
    label.Text                   = player.Name
    label.TextColor3             = Color3.fromRGB(255, 255, 255)
    label.TextStrokeTransparency = 0
    label.TextScaled             = false
    label.TextSize               = Settings.NameSize
    label.Font                   = Enum.Font.GothamBold
    label.Parent                 = bg

    nameBillboards[player] = bg
end

local function removeNameBillboard(player)
    if nameBillboards[player] then
        nameBillboards[player]:Destroy()
        nameBillboards[player] = nil
    end
end

-- =====================
-- DISTANCE BILLBOARD
-- =====================

local function addDistanceBillboard(player, character)
    if not Settings.DistanceEnabled then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if distanceBillboards[player] then distanceBillboards[player]:Destroy() end

    local bg = Instance.new("BillboardGui")
    bg.Name        = "ESPDistance"
    bg.Adornee     = hrp
    bg.Size        = UDim2.new(0, 200, 0, 20)
    bg.StudsOffset = Vector3.new(0, 1.5, 0)
    bg.AlwaysOnTop = true
    bg.Parent      = hrp

    local label = Instance.new("TextLabel")
    label.Name                   = "DistanceLabel"
    label.BackgroundTransparency = 1
    label.Size                   = UDim2.new(1, 0, 1, 0)
    label.Text                   = "0m"
    label.TextColor3             = Color3.fromRGB(255, 220, 50)
    label.TextStrokeTransparency = 0
    label.TextScaled             = false
    label.TextSize               = 13
    label.Font                   = Enum.Font.Gotham
    label.Parent                 = bg

    distanceBillboards[player] = bg
end

local function removeDistanceBillboard(player)
    if distanceBillboards[player] then
        distanceBillboards[player]:Destroy()
        distanceBillboards[player] = nil
    end
end

-- =====================
-- CLEANUP / REFRESH
-- =====================

local function cleanupPlayer(player)
    if player.Character then removeHighlight(player.Character) end
    removeHitbox(player)
    removeNameBillboard(player)
    removeDistanceBillboard(player)
end

local function refreshCharacter(player, character)
    if not character then return end
    removeHighlight(character)
    removeHitbox(player)
    removeNameBillboard(player)
    removeDistanceBillboard(player)
    addHighlight(character)
    addHitbox(player, character)
    addNameBillboard(player, character)
    addDistanceBillboard(player, character)
end

local function refreshAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if player.Character then
            refreshCharacter(player, player.Character)
        end
    end
end

-- =====================
-- PLAYER HANDLING
-- =====================

local function onPlayerAdded(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function(char)
        task.wait(1)
        refreshCharacter(player, char)
    end)
    if player.Character then
        refreshCharacter(player, player.Character)
    end
end

Players.PlayerRemoving:Connect(cleanupPlayer)

for _, p in ipairs(Players:GetPlayers()) do onPlayerAdded(p) end
Players.PlayerAdded:Connect(onPlayerAdded)

-- =====================
-- LOOPS
-- =====================

task.spawn(function()
    while true do
        task.wait(1)
        refreshAll()
    end
end)

RunService.RenderStepped:Connect(function()
    if not Settings.DistanceEnabled then return end
    local localChar = LocalPlayer.Character
    local localHRP  = localChar and localChar:FindFirstChild("HumanoidRootPart")
    if not localHRP then return end

    for player, bg in pairs(distanceBillboards) do
        if not bg or not bg.Parent then
            distanceBillboards[player] = nil
            continue
        end
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local dist        = math.floor((localHRP.Position - hrp.Position).Magnitude)
        local beyondRange = dist > Settings.MaxDistance
        local label       = bg:FindFirstChild("DistanceLabel")

        bg.Enabled = not beyondRange
        if label then label.Text = dist .. "m" end

        local highlight = char:FindFirstChild("PlayerHighlight")
        if highlight then highlight.Enabled = Settings.ESPEnabled and not beyondRange end

        if hitboxData[player] and hitboxData[player].box then
            hitboxData[player].box.Visible = Settings.HitboxEnabled and not beyondRange
        end

        local nameBg = nameBillboards[player]
        if nameBg then nameBg.Enabled = Settings.NamesEnabled and not beyondRange end
    end
end)

