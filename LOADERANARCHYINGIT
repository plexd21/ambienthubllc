        })
    end,
})

KeybindsTab:CreateKeybind({
    Name           = "Toggle Names",
    CurrentKeybind = "F2",
    HoldToInteract = false,
    Flag           = "KeyNames",
    Callback       = function()
        Settings.NamesEnabled = not Settings.NamesEnabled
        if UIToggles["NamesToggle"] then UIToggles["NamesToggle"]:Set(Settings.NamesEnabled) end
        if Settings.NamesEnabled then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then addNameBillboard(p, p.Character) end
            end
