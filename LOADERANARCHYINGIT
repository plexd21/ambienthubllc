    Flag           = "KeyDistance",
    Callback       = function()
        Settings.DistanceEnabled = not Settings.DistanceEnabled
        if UIToggles["DistToggle"] then UIToggles["DistToggle"]:Set(Settings.DistanceEnabled) end
        if Settings.DistanceEnabled then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then addDistanceBillboard(p, p.Character) end
            end
        else
            for _, p in ipairs(Players:GetPlayers()) do removeDistanceBillboard(p) end
        end
        Rayfield:Notify({
            Title    = "Anarchying It V.1",
            Content  = "Distance " .. (Settings.DistanceEnabled and "Enabled" or "Disabled"),
