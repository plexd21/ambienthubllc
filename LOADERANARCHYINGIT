-- KEYBIND HINT UI
-- =====================

local keybindHintGui = Instance.new("ScreenGui")
keybindHintGui.Name            = "KeybindHints"
keybindHintGui.ResetOnSpawn    = false
keybindHintGui.Enabled         = false
keybindHintGui.Parent          = LocalPlayer:WaitForChild("PlayerGui")

local hintFrame = Instance.new("Frame")
hintFrame.Size                   = UDim2.new(0, 240, 0, #KeybindRegistry * 28 + 36)
hintFrame.Position               = UDim2.new(1, -250, 0.5, -((#KeybindRegistry * 28 + 36) / 2))
hintFrame.BackgroundColor3       = Color3.fromRGB(15, 15, 15)
hintFrame.BackgroundTransparency = 0.25
hintFrame.BorderSizePixel        = 0
hintFrame.Parent                 = keybindHintGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent       = hintFrame

local titleLabel = Instance.new("TextLabel")
titleLabel.Size                   = UDim2.new(1, 0, 0, 28)
titleLabel.Position               = UDim2.new(0, 0, 0, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.Text                   = "⌨  Keybinds"
titleLabel.TextColor3             = Color3.fromRGB(255, 200, 50)
titleLabel.TextSize               = 13
titleLabel.Font                   = Enum.Font.GothamBold
titleLabel.Parent                 = hintFrame

-- Row labels stored so we can refresh their text
local hintRows = {}
for i, hint in ipairs(KeybindRegistry) do
    local row = Instance.new("TextLabel")
    row.Size                   = UDim2.new(1, -16, 0, 22)
    row.Position               = UDim2.new(0, 8, 0, 24 + (i - 1) * 26)
    row.BackgroundTransparency = 1
    row.TextColor3             = Color3.fromRGB(210, 210, 210)
    row.TextSize               = 12
    row.Font                   = Enum.Font.Gotham
    row.TextXAlignment         = Enum.TextXAlignment.Left
    row.Text                   = "[" .. hint.key .. "]  " .. hint.action
    row.Parent                 = hintFrame
    hintRows[i] = row
end

-- Reads current keybind values from Rayfield's shared flags table and rebuilds rows
local function refreshHintRows()
    for i, hint in ipairs(KeybindRegistry) do
        local currentKey = hint.key
        -- Rayfield stores keybind values in RayfieldLibrary.Flags
        pcall(function()
            local flagVal = Rayfield.Flags[hint.flag]
            if flagVal and flagVal ~= "" then
                currentKey = tostring(flagVal)
            end
        end)
        if hintRows[i] then
            hintRows[i].Text = "[" .. currentKey .. "]  " .. hint.action
        end
    end
end

local function setKeybindHints(enabled)
    Settings.KeybindHintsEnabled = enabled
    keybindHintGui.Enabled       = enabled
    if enabled then refreshHintRows() end
end

-- Auto-refresh every 60 seconds so reassigned keys stay accurate
task.spawn(function()
    while true do
        task.wait(60)
        if Settings.KeybindHintsEnabled then
            refreshHintRows()
        end
    end
end)

