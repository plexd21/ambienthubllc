-- =====================
-- TELEPORT
-- =====================

local function getPlayerNames()
    local names = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then table.insert(names, p.Name) end
    end
    return names
end

local function teleportToTarget()
    local target = Settings.TeleportTarget
    if not target or target == "" then
        Rayfield:Notify({ Title = "Rage", Content = "No player selected.", Duration = 2 })
        return
    end
    local targetPlayer = Players:FindFirstChild(target)
    if not targetPlayer then
        Rayfield:Notify({ Title = "Rage", Content = target .. " is not in the game.", Duration = 2 })
        return
    end
    local targetHRP = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local localHRP  = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if targetHRP and localHRP then
        localHRP.CFrame = targetHRP.CFrame + Vector3.new(0, 3, 0)
        Rayfield:Notify({ Title = "Rage", Content = "Teleported to " .. target, Duration = 1.5 })
    else
        Rayfield:Notify({ Title = "Rage", Content = "Could not teleport — character not loaded.", Duration = 2 })
    end
end

local function startTeleportLoop()
    if teleportThread then task.cancel(teleportThread) teleportThread = nil end
    teleportThread = task.spawn(function()
        while Settings.TeleportLoopEnabled do
            teleportToTarget()
            task.wait(Settings.TeleportDelay)
        end
    end)
end

local function stopTeleportLoop()
    Settings.TeleportLoopEnabled = false
    if teleportThread then task.cancel(teleportThread) teleportThread = nil end
end

local function refreshPlayerDropdown()
    if not playerDropdown then return end
    pcall(function() playerDropdown:Refresh(getPlayerNames(), true) end)
end

Players.PlayerAdded:Connect(function(p)
    if p ~= LocalPlayer then task.wait(1) refreshPlayerDropdown() end
end)

Players.PlayerRemoving:Connect(function(p)
    if Settings.TeleportTarget == p.Name then
        Settings.TeleportTarget = nil
        stopTeleportLoop()
        if UIToggles["TeleportLoopToggle"] then UIToggles["TeleportLoopToggle"]:Set(false) end
        Rayfield:Notify({ Title = "Rage", Content = p.Name .. " left the game.", Duration = 2 })
    end
    task.wait(0.1)
    refreshPlayerDropdown()
end)

-- =====================
-- HIGHLIGHT
-- =====================

local function addHighlight(character)
    if not Settings.ESPEnabled then return end
    if character:FindFirstChild("PlayerHighlight") then return end
    local h = Instance.new("Highlight")
    h.Name                = "PlayerHighlight"
    h.FillColor           = Settings.FillColor
    h.OutlineColor        = Settings.OutlineColor
    h.FillTransparency    = Settings.FillTransparency
    h.OutlineTransparency = 0
    h.Parent              = character
end

local function removeHighlight(character)
    local h = character:FindFirstChild("PlayerHighlight")
    if h then h:Destroy() end
end

-- =====================
-- NAME BILLBOARD
-- =====================

local function addNameBillboard(player, character)
    if not Settings.NamesEnabled then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if nameBillboards[player] then nameBillboards[player]:Destroy() end

    local bg = Instance.new("BillboardGui")
    bg.Name        = "ESPName"
    bg.Adornee     = hrp
    bg.Size        = UDim2.new(0, 200, 0, 30)
    bg.StudsOffset = Vector3.new(0, 3, 0)
    bg.AlwaysOnTop = true
    bg.Parent      = hrp

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size                   = UDim2.new(1, 0, 1, 0)
    label.Text                   = player.Name
    label.TextColor3             = Color3.fromRGB(255, 255, 255)
    label.TextStrokeTransparency = 0
    label.TextScaled             = false
    label.TextSize               = Settings.NameSize
    label.Font                   = Enum.Font.GothamBold
    label.Parent                 = bg

    nameBillboards[player] = bg
end

local function removeNameBillboard(player)
    if nameBillboards[player] then
        nameBillboards[player]:Destroy()
        nameBillboards[player] = nil
    end
end

-- =====================
-- DISTANCE BILLBOARD
-- =====================

local function addDistanceBillboard(player, character)
    if not Settings.DistanceEnabled then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if distanceBillboards[player] then distanceBillboards[player]:Destroy() end

    local bg = Instance.new("BillboardGui")
    bg.Name        = "ESPDistance"
    bg.Adornee     = hrp
    bg.Size        = UDim2.new(0, 200, 0, 20)
    bg.StudsOffset = Vector3.new(0, 1.5, 0)
    bg.AlwaysOnTop = true
    bg.Parent      = hrp

    local label = Instance.new("TextLabel")
    label.Name                   = "DistanceLabel"
    label.BackgroundTransparency = 1
    label.Size                   = UDim2.new(1, 0, 1, 0)
    label.Text                   = "0m"
    label.TextColor3             = Color3.fromRGB(255, 220, 50)
    label.TextStrokeTransparency = 0
    label.TextScaled             = false
    label.TextSize               = 13
    label.Font                   = Enum.Font.Gotham
    label.Parent                 = bg

    distanceBillboards[player] = bg
end

local function removeDistanceBillboard(player)
    if distanceBillboards[player] then
        distanceBillboards[player]:Destroy()
        distanceBillboards[player] = nil
    end
end

-- =====================
-- TRACER LINES
-- =====================

local function addTracer(player)
    if not Settings.TracerEnabled then return end
    if tracerLines[player] then tracerLines[player]:Remove() end
    local line = Drawing.new("Line")
    line.Visible      = false
    line.Color        = Color3.fromRGB(255, 50, 50)
    line.Thickness    = 1
    line.Transparency = 1
    tracerLines[player] = line
end

local function removeTracer(player)
    if tracerLines[player] then
        tracerLines[player]:Remove()
        tracerLines[player] = nil
    end
end

local function removeAllTracers()
    for player, line in pairs(tracerLines) do
        if line then line:Remove() end
        tracerLines[player] = nil
    end
end

-- =====================
-- CLEANUP / REFRESH
-- =====================

local function cleanupPlayer(player)
    if player.Character then removeHighlight(player.Character) end
    removeNameBillboard(player)
    removeDistanceBillboard(player)
    removeTracer(player)
end

local function refreshCharacter(player, character)
    if not character then return end
    removeHighlight(character)
    removeNameBillboard(player)
    removeDistanceBillboard(player)
    removeTracer(player)
    addHighlight(character)
    addNameBillboard(player, character)
    addDistanceBillboard(player, character)
    addTracer(player)
end

local function refreshAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if player.Character then refreshCharacter(player, player.Character) end
    end
end

-- =====================
-- PLAYER HANDLING
-- =====================

local function onPlayerAdded(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function(char)
        task.wait(1)
        refreshCharacter(player, char)
    end)
    if player.Character then refreshCharacter(player, player.Character) end
end

for _, p in ipairs(Players:GetPlayers()) do onPlayerAdded(p) end
Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(cleanupPlayer)

-- =====================
-- LOOPS
-- =====================

task.spawn(function()
    while true do
        task.wait(1)
        refreshAll()
    end
end)

RunService.RenderStepped:Connect(function()
    local localChar = LocalPlayer.Character
    local localHRP  = localChar and localChar:FindFirstChild("HumanoidRootPart")
    local camera    = workspace.CurrentCamera

    -- Tracer lines
    if Settings.TracerEnabled and localHRP and camera then
        local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
        for player, line in pairs(tracerLines) do
            if not line then tracerLines[player] = nil continue end
            local char = player.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (localHRP.Position - hrp.Position).Magnitude
                if dist <= Settings.MaxDistance then
                    local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                    if onScreen then
                        line.From        = screenCenter
                        line.To          = Vector2.new(screenPos.X, screenPos.Y)
                        line.Visible     = true
                        line.Transparency = 1
                    else
                        line.Visible = false
                    end
                else
                    line.Visible = false
                end
            else
                line.Visible = false
            end
        end
    else
        for _, line in pairs(tracerLines) do
            if line then line.Visible = false end
        end
    end

    -- Distance labels
    if not Settings.DistanceEnabled then return end
    if not localHRP then return end

    for player, bg in pairs(distanceBillboards) do
        if not bg or not bg.Parent then distanceBillboards[player] = nil continue end
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local dist        = math.floor((localHRP.Position - hrp.Position).Magnitude)
        local beyondRange = dist > Settings.MaxDistance
        local label       = bg:FindFirstChild("DistanceLabel")

        bg.Enabled = not beyondRange
        if label then label.Text = dist .. "m" end

        local highlight = char:FindFirstChild("PlayerHighlight")
        if highlight then highlight.Enabled = Settings.ESPEnabled and not beyondRange end

        local nameBg = nameBillboards[player]
        if nameBg then nameBg.Enabled = Settings.NamesEnabled and not beyondRange end
    end
end)

