-- State
local Settings = {
    ESPEnabled = false,
    NamesEnabled = false,
    DistanceEnabled = false,
    TracerEnabled = false,
    FillColor = Color3.fromRGB(255, 0, 0),
    OutlineColor = Color3.fromRGB(255, 255, 255),
    FillTransparency = 0.5,
    MaxDistance = 10000,
    NameSize = 14,
    TeleportTarget = nil,
    TeleportLoopEnabled = false,
    TeleportDelay = 2,
    KeybindHintsEnabled = false,
}

local nameBillboards     = {}
local distanceBillboards = {}
local tracerLines        = {}
local UIToggles          = {}
local teleportThread     = nil
local playerDropdown     = nil

-- Keybind registry — updated live when player reassigns
local KeybindRegistry = {
    { flag = "KeyESP",           action = "Toggle Highlights",    key = "F1" },
    { flag = "KeyNames",         action = "Toggle Names",         key = "F2" },
    { flag = "KeyDistance",      action = "Toggle Distance",      key = "F3" },
    { flag = "KeyTeleportOnce",  action = "Teleport Once",        key = "F4" },
    { flag = "KeyTeleportLoop",  action = "Toggle Teleport Loop", key = "F5" },
