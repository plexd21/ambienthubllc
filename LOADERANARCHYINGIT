--// Anarchying It V.1
--// Place in a LocalScript inside StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local SoundService = game:GetService("SoundService")

-- Load Rayfield
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

-- State
local Settings = {
    ESPEnabled = false,
    NamesEnabled = false,
    DistanceEnabled = false,
    FillColor = Color3.fromRGB(255, 0, 0),
    OutlineColor = Color3.fromRGB(255, 255, 255),
    FillTransparency = 0.5,
    MaxDistance = 10000,
    NameSize = 14,
    TextureEnabled = false,
    BulletSoundEnabled = false,
    BulletSoundId = "832380497",
    TeleportLoopEnabled = false,
    TeleportDelay = 2,
}

local nameBillboards     = {}
local distanceBillboards = {}
local UIToggles          = {}

-- =====================
-- TEXTURE
-- =====================

local TEXTURE_ID = "rbxassetid://5226483487"
local appliedTextures = {}

local function applyTexture()
    local character = LocalPlayer.Character
    if not character then return end
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            -- Remove existing decals/textures we added
            for _, d in ipairs(part:GetChildren()) do
                if d:IsA("Decal") and d.Name == "ESPTexture" then d:Destroy() end
            end
            for _, face in ipairs({
                Enum.NormalId.Front, Enum.NormalId.Back,
                Enum.NormalId.Left,  Enum.NormalId.Right,
                Enum.NormalId.Top,   Enum.NormalId.Bottom,
            }) do
                local decal = Instance.new("Decal")
                decal.Name     = "ESPTexture"
                decal.Texture  = TEXTURE_ID
                decal.Face     = face
                decal.Parent   = part
                table.insert(appliedTextures, decal)
            end
        end
    end
    -- Also apply to Shirt/Pants by removing them and using decals
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        for _, obj in ipairs(character:GetChildren()) do
            if obj:IsA("Shirt") or obj:IsA("Pants") then
                obj.Parent = nil
                table.insert(appliedTextures, obj) -- store for restoration
            end
        end
    end
end

local function removeTexture()
    for _, d in ipairs(appliedTextures) do
        if d and d.Parent then
            d:Destroy()
        elseif d and (d:IsA("Shirt") or d:IsA("Pants")) then
            d.Parent = LocalPlayer.Character
        end
    end
    appliedTextures = {}
end

-- =====================
-- BULLET SOUND
-- =====================

local bulletSound = nil
local bulletConnection = nil

local function setupBulletSound()
    if bulletSound then bulletSound:Destroy() end
    bulletSound = Instance.new("Sound")
    bulletSound.Name     = "BulletHitSound"
    bulletSound.SoundId  = "rbxassetid://" .. Settings.BulletSoundId
    bulletSound.Volume   = 1
    bulletSound.RollOffMaxDistance = 999999
    bulletSound.Parent   = SoundService
end

local function enableBulletSound()
    setupBulletSound()
    -- Listen for the local character taking damage as a proxy for being shot
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    if bulletConnection then bulletConnection:Disconnect() end
    bulletConnection = humanoid.HealthChanged:Connect(function(newHealth)
        if not Settings.BulletSoundEnabled then return end
        if newHealth < humanoid.MaxHealth then
            if bulletSound and not bulletSound.IsPlaying then
                bulletSound:Play()
            end
        end
    end)
end

local function disableBulletSound()
    if bulletConnection then
        bulletConnection:Disconnect()
        bulletConnection = nil
    end
    if bulletSound then
        bulletSound:Stop()
    end
end

-- =====================
-- TELEPORT LOOP
-- =====================

local teleportThread = nil

local function startTeleportLoop()
    if teleportThread then
        task.cancel(teleportThread)
        teleportThread = nil
    end

    teleportThread = task.spawn(function()
        while Settings.TeleportLoopEnabled do
            for _, player in ipairs(Players:GetPlayers()) do
                if not Settings.TeleportLoopEnabled then break end
                if player == LocalPlayer then continue end

                local targetChar = player.Character
                local targetHRP  = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
                local localChar  = LocalPlayer.Character
                local localHRP   = localChar and localChar:FindFirstChild("HumanoidRootPart")

                if targetHRP and localHRP then
                    localHRP.CFrame = targetHRP.CFrame + Vector3.new(0, 3, 0)
                    Rayfield:Notify({
                        Title    = "Rage",
                        Content  = "Teleported to " .. player.Name,
                        Duration = 1,
                    })
                end

                task.wait(Settings.TeleportDelay)
            end
        end
    end)
end

local function stopTeleportLoop()
    Settings.TeleportLoopEnabled = false
    if teleportThread then
        task.cancel(teleportThread)
        teleportThread = nil
    end
end

-- =====================
-- HIGHLIGHT
-- =====================

local function addHighlight(character)
    if not Settings.ESPEnabled then return end
    if character:FindFirstChild("PlayerHighlight") then return end
    local h = Instance.new("Highlight")
    h.Name                = "PlayerHighlight"
    h.FillColor           = Settings.FillColor
    h.OutlineColor        = Settings.OutlineColor
    h.FillTransparency    = Settings.FillTransparency
    h.OutlineTransparency = 0
    h.Parent              = character
end

local function removeHighlight(character)
    local h = character:FindFirstChild("PlayerHighlight")
    if h then h:Destroy() end
end

-- =====================
-- NAME BILLBOARD
-- =====================

local function addNameBillboard(player, character)
    if not Settings.NamesEnabled then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if nameBillboards[player] then nameBillboards[player]:Destroy() end

    local bg = Instance.new("BillboardGui")
    bg.Name        = "ESPName"
    bg.Adornee     = hrp
    bg.Size        = UDim2.new(0, 200, 0, 30)
    bg.StudsOffset = Vector3.new(0, 3, 0)
    bg.AlwaysOnTop = true
    bg.Parent      = hrp

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size                   = UDim2.new(1, 0, 1, 0)
    label.Text                   = player.Name
    label.TextColor3             = Color3.fromRGB(255, 255, 255)
    label.TextStrokeTransparency = 0
    label.TextScaled             = false
    label.TextSize               = Settings.NameSize
    label.Font                   = Enum.Font.GothamBold
    label.Parent                 = bg

    nameBillboards[player] = bg
end

local function removeNameBillboard(player)
    if nameBillboards[player] then
        nameBillboards[player]:Destroy()
        nameBillboards[player] = nil
    end
end

-- =====================
-- DISTANCE BILLBOARD
-- =====================

local function addDistanceBillboard(player, character)
    if not Settings.DistanceEnabled then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if distanceBillboards[player] then distanceBillboards[player]:Destroy() end

    local bg = Instance.new("BillboardGui")
    bg.Name        = "ESPDistance"
    bg.Adornee     = hrp
    bg.Size        = UDim2.new(0, 200, 0, 20)
    bg.StudsOffset = Vector3.new(0, 1.5, 0)
    bg.AlwaysOnTop = true
    bg.Parent      = hrp

    local label = Instance.new("TextLabel")
    label.Name                   = "DistanceLabel"
    label.BackgroundTransparency = 1
    label.Size                   = UDim2.new(1, 0, 1, 0)
    label.Text                   = "0m"
    label.TextColor3             = Color3.fromRGB(255, 220, 50)
    label.TextStrokeTransparency = 0
    label.TextScaled             = false
    label.TextSize               = 13
    label.Font                   = Enum.Font.Gotham
    label.Parent                 = bg

    distanceBillboards[player] = bg
end

local function removeDistanceBillboard(player)
    if distanceBillboards[player] then
        distanceBillboards[player]:Destroy()
        distanceBillboards[player] = nil
    end
end

-- =====================
-- CLEANUP / REFRESH
-- =====================

local function cleanupPlayer(player)
    if player.Character then removeHighlight(player.Character) end
    removeNameBillboard(player)
    removeDistanceBillboard(player)
end

local function refreshCharacter(player, character)
    if not character then return end
    removeHighlight(character)
    removeNameBillboard(player)
    removeDistanceBillboard(player)
    addHighlight(character)
    addNameBillboard(player, character)
    addDistanceBillboard(player, character)
end

local function refreshAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if player.Character then
            refreshCharacter(player, player.Character)
        end
    end
end

-- =====================
-- PLAYER HANDLING
-- =====================

local function onPlayerAdded(player)
    if player == LocalPlayer then return end
    player.CharacterAdded:Connect(function(char)
        task.wait(1)
        refreshCharacter(player, char)
    end)
    if player.Character then
        refreshCharacter(player, player.Character)
    end
end

Players.PlayerRemoving:Connect(cleanupPlayer)

-- Re-apply texture and bullet sound on respawn
LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(1)
    if Settings.TextureEnabled then applyTexture() end
    if Settings.BulletSoundEnabled then enableBulletSound() end
end)

for _, p in ipairs(Players:GetPlayers()) do onPlayerAdded(p) end
Players.PlayerAdded:Connect(onPlayerAdded)

-- =====================
-- LOOPS
-- =====================

task.spawn(function()
    while true do
        task.wait(1)
        refreshAll()
    end
end)

RunService.RenderStepped:Connect(function()
    if not Settings.DistanceEnabled then return end
    local localChar = LocalPlayer.Character
    local localHRP  = localChar and localChar:FindFirstChild("HumanoidRootPart")
    if not localHRP then return end

    for player, bg in pairs(distanceBillboards) do
        if not bg or not bg.Parent then
            distanceBillboards[player] = nil
            continue
        end
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end

        local dist        = math.floor((localHRP.Position - hrp.Position).Magnitude)
        local beyondRange = dist > Settings.MaxDistance
        local label       = bg:FindFirstChild("DistanceLabel")

        bg.Enabled = not beyondRange
        if label then label.Text = dist .. "m" end

        local highlight = char:FindFirstChild("PlayerHighlight")
        if highlight then highlight.Enabled = Settings.ESPEnabled and not beyondRange end

        local nameBg = nameBillboards[player]
        if nameBg then nameBg.Enabled = Settings.NamesEnabled and not beyondRange end
    end
end)

