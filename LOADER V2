-- =====================
-- UNINJECT
-- =====================
local function uninject()
    Settings.TeleportLoopEnabled    = false
    Settings.SpeedEnabled           = false
    Settings.ProximityAlertsEnabled = false
    Settings.NoclipEnabled          = false

    if teleportThread then task.cancel(teleportThread) teleportThread = nil end
    if speedPushConn  then speedPushConn:Disconnect()  speedPushConn  = nil end
    if noclipConn     then noclipConn:Disconnect()     noclipConn     = nil end

    pcall(function()
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = 16 end
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = true end
            end
        end
    end)

    for _, player in ipairs(Players:GetPlayers()) do
        pcall(function()
            if player.Character then
                local h = player.Character:FindFirstChild("PlayerHighlight")
                if h then h:Destroy() end
            end
        end)
        if nameBillboards[player]     then nameBillboards[player]:Destroy()     nameBillboards[player]     = nil end
        if distanceBillboards[player] then distanceBillboards[player]:Destroy() distanceBillboards[player] = nil end
        if tracerLines[player]        then tracerLines[player]:Remove()         tracerLines[player]        = nil end
    end

    pcall(function()
        local pg = LocalPlayer:FindFirstChild("PlayerGui")
        if pg then
            for _, gui in ipairs(pg:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Name == "ProximityAlerts" then gui:Destroy() end
            end
        end
    end)

    pcall(function() Rayfield:Destroy() end)
    task.wait(0.3)
    LocalPlayer:Kick("Anarchying It has been uninjected. Please rejoin.")
end

-- =====================
-- TELEPORT
-- =====================
local function getPlayerNames()
    local names = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then table.insert(names, p.Name) end
    end
    return names
end

local function teleportToTarget()
    local target = Settings.TeleportTarget
    if not target or target == "" then
        Rayfield:Notify({ Title = "Rage", Content = "No player selected.", Duration = 2 })
        return
    end
    local tp = Players:FindFirstChild(target)
    if not tp then
        Rayfield:Notify({ Title = "Rage", Content = target .. " not in game.", Duration = 2 })
        return
    end
    local tHRP = tp.Character and tp.Character:FindFirstChild("HumanoidRootPart")
    local lHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if tHRP and lHRP then
        lHRP.CFrame = tHRP.CFrame + Vector3.new(0, 3, 0)
        Rayfield:Notify({ Title = "Rage", Content = "Teleported to " .. target, Duration = 1.5 })
    else
        Rayfield:Notify({ Title = "Rage", Content = "Character not loaded.", Duration = 2 })
    end
end

local function startTeleportLoop()
    if teleportThread then task.cancel(teleportThread) teleportThread = nil end
    teleportThread = task.spawn(function()
        while Settings.TeleportLoopEnabled do
            teleportToTarget()
            task.wait(Settings.TeleportDelay)
        end
    end)
end

local function stopTeleportLoop()
    Settings.TeleportLoopEnabled = false
    if teleportThread then task.cancel(teleportThread) teleportThread = nil end
end

local function refreshPlayerDropdown()
    if not playerDropdown then return end
    pcall(function() playerDropdown:Refresh(getPlayerNames(), true) end)
end

Players.PlayerAdded:Connect(function(p)
    if p ~= LocalPlayer then task.wait(1) refreshPlayerDropdown() end
end)

Players.PlayerRemoving:Connect(function(p)
    if Settings.TeleportTarget == p.Name then
        Settings.TeleportTarget = nil
        stopTeleportLoop()
        if UIToggles["TeleportLoopToggle"] then UIToggles["TeleportLoopToggle"]:Set(false) end
        Rayfield:Notify({ Title = "Rage", Content = p.Name .. " left.", Duration = 2 })
    end
    task.wait(0.1)
    refreshPlayerDropdown()
end)

