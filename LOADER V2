-- SPEED  (1x–100x)
-- =====================
local DEFAULT_WALKSPEED = 16
local DEFAULT_HIPHEIGHT = 0

local function applySpeed(multiplier)
    if not Settings.SpeedEnabled then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    hum.WalkSpeed = math.min(DEFAULT_WALKSPEED * multiplier, 200)
    if DEFAULT_HIPHEIGHT == 0 then DEFAULT_HIPHEIGHT = hum.HipHeight end
    hum.HipHeight = DEFAULT_HIPHEIGHT
end

local function resetSpeed()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then hum.WalkSpeed = DEFAULT_WALKSPEED end
end

local function startSpeedPusher()
    if speedPushConn then speedPushConn:Disconnect() end
    speedPushConn = RunService.Heartbeat:Connect(function()
        if not Settings.SpeedEnabled or Settings.SpeedMultiplier <= 12 then return end
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end
        if hum.MoveDirection.Magnitude == 0 then return end
        local overflow = (DEFAULT_WALKSPEED * Settings.SpeedMultiplier) - 200
        if overflow <= 0 then return end
        hrp.CFrame = hrp.CFrame + (hum.MoveDirection * overflow * 0.016)
    end)
end

startSpeedPusher()

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    DEFAULT_HIPHEIGHT = 0
    if Settings.SpeedEnabled then applySpeed(Settings.SpeedMultiplier) end
end)

-- =====================
-- NOCLIP  (workspace-wide phase-through)
-- Every Heartbeat we disable CanCollide on our character's parts.
-- We also set CanCollide false on any workspace part our HRP is touching,
-- then restore them immediately after — this phases through EVERYTHING
-- including terrain-adjacent parts and moving obstacles.
-- =====================
local noclipTouchedParts = {}  -- parts we temporarily disabled

local function startNoclip()
    if noclipConn then noclipConn:Disconnect() end
    noclipConn = RunService.Heartbeat:Connect(function()
        -- Restore previously touched world parts
        for part, orig in pairs(noclipTouchedParts) do
            pcall(function() part.CanCollide = orig end)
        end
        noclipTouchedParts = {}

        if not Settings.NoclipEnabled then return end

        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")

        -- Disable collision on all character parts
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end

        -- Also disable any touching workspace parts (so we phase through walls/floors)
        if hrp then
            local touching = hrp:GetTouchingParts()
            for _, part in ipairs(touching) do
                -- Only target parts NOT in our character
                if part:IsDescendantOf(char) then continue end
                if part:IsA("BasePart") then
                    noclipTouchedParts[part] = part.CanCollide
                    part.CanCollide = false
                end
            end
        end
    end)
end

local function stopNoclip()
    Settings.NoclipEnabled = false
    -- Restore all world parts we touched
    for part, orig in pairs(noclipTouchedParts) do
        pcall(function() part.CanCollide = orig end)
    end
    noclipTouchedParts = {}
    -- Restore character collisions
    pcall(function()
        local char = LocalPlayer.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = true end
            end
        end
    end)
end

startNoclip()

