local function getOrCreateCard(player)
    if proximityCards[player] then return proximityCards[player] end
    local c = Instance.new("Frame")
    c.Name                   = "Card_" .. player.Name
    c.Size                   = UDim2.new(1, 0, 0, 54)
    c.BackgroundColor3       = Color3.fromRGB(15, 15, 15)
    c.BackgroundTransparency = 0.2
    c.BorderSizePixel        = 0
    c.Visible                = false
    c.Parent                 = proximityFrame
    local cc2 = Instance.new("UICorner") cc2.CornerRadius = UDim.new(0,6) cc2.Parent = c
    local accent = Instance.new("Frame")
    accent.Name             = "Accent"
    accent.Size             = UDim2.new(0, 4, 1, 0)
    accent.BackgroundColor3 = Color3.fromRGB(0, 255, 80)
    accent.BorderSizePixel  = 0
    accent.Parent           = c
    local ac2 = Instance.new("UICorner") ac2.CornerRadius = UDim.new(0,6) ac2.Parent = accent
    local avatarImg = Instance.new("ImageLabel")
    avatarImg.Size                   = UDim2.new(0, 40, 0, 40)
    avatarImg.Position               = UDim2.new(0, 10, 0.5, -20)
    avatarImg.BackgroundColor3       = Color3.fromRGB(40,40,40)
    avatarImg.BorderSizePixel        = 0
    avatarImg.Image                  = "rbxthumb://type=AvatarHeadShot&id=" .. player.UserId .. "&w=48&h=48"
    avatarImg.Parent                 = c
    local av2 = Instance.new("UICorner") av2.CornerRadius = UDim.new(0.5,0) av2.Parent = avatarImg
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size                   = UDim2.new(1,-62,0,22)
    nameLabel.Position               = UDim2.new(0,58,0,8)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text                   = player.Name
    nameLabel.TextColor3             = Color3.fromRGB(240,240,240)
    nameLabel.TextSize               = 13
    nameLabel.Font                   = Enum.Font.GothamBold
    nameLabel.TextXAlignment         = Enum.TextXAlignment.Left
    nameLabel.TextTruncate           = Enum.TextTruncate.AtEnd
    nameLabel.Parent                 = c
    local distLabel = Instance.new("TextLabel")
    distLabel.Size                   = UDim2.new(1,-62,0,18)
    distLabel.Position               = UDim2.new(0,58,0,30)
    distLabel.BackgroundTransparency = 1
    distLabel.Text                   = "0m away"
    distLabel.TextColor3             = Color3.fromRGB(180,180,180)
    distLabel.TextSize               = 11
    distLabel.Font                   = Enum.Font.Gotham
    distLabel.TextXAlignment         = Enum.TextXAlignment.Left
    distLabel.Parent                 = c
    proximityCards[player] = { frame = c, accent = accent, distLabel = distLabel }
    return proximityCards[player]
end

local function removeProximityCard(player)
    if proximityCards[player] then
        proximityCards[player].frame:Destroy()
        proximityCards[player] = nil
    end
    proxPlayerWasInRange[player] = nil
end
Players.PlayerRemoving:Connect(removeProximityCard)

-- =====================
-- RENDER LOOP
-- =====================
RunService.RenderStepped:Connect(function()
    local localChar = LocalPlayer.Character
    local localHRP  = localChar and localChar:FindFirstChild("HumanoidRootPart")
    local camera    = workspace.CurrentCamera

    -- Tracers
    if Settings.TracerEnabled and localHRP and camera then
        local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
        for player, line in pairs(tracerLines) do
            if not line then tracerLines[player] = nil continue end
            local char = player.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (localHRP.Position - hrp.Position).Magnitude
                if dist <= Settings.MaxDistance then
                    local sp, onScreen = camera:WorldToViewportPoint(hrp.Position)
                    if onScreen then
                        line.From         = screenCenter
                        line.To           = Vector2.new(sp.X, sp.Y)
                        line.Visible      = true
                        line.Transparency = 1
                    else
                        line.Visible = false
                    end
                else
                    line.Visible = false
                end
            else
                line.Visible = false
            end
        end
    else
        for _, line in pairs(tracerLines) do
            if line then line.Visible = false end
        end
    end

    -- Distance labels
    if Settings.DistanceEnabled and localHRP then
        for player, bg in pairs(distanceBillboards) do
            if not bg or not bg.Parent then distanceBillboards[player] = nil continue end
            local char = player.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end
            local dist        = math.floor((localHRP.Position - hrp.Position).Magnitude)
            local beyondRange = dist > Settings.MaxDistance
            local label       = bg:FindFirstChild("DistanceLabel")
            bg.Enabled = not beyondRange
            if label then label.Text = dist .. "m" end
            local highlight = char:FindFirstChild("PlayerHighlight")
            if highlight then highlight.Enabled = Settings.ESPEnabled and not beyondRange end
            local nameBg = nameBillboards[player]
            if nameBg then nameBg.Enabled = Settings.NamesEnabled and not beyondRange end
        end
    end

    -- Proximity alerts
    if not Settings.ProximityAlertsEnabled or not localHRP then
        for _, cardData in pairs(proximityCards) do
            if cardData.frame then cardData.frame.Visible = false end
        end
        return
    end

    local maxDist = Settings.ProximityDistance
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then
            local cd = proximityCards[player]
            if cd then cd.frame.Visible = false end
            proxPlayerWasInRange[player] = false
            continue
        end
        local dist    = math.floor((localHRP.Position - hrp.Position).Magnitude)
        local inRange = dist <= maxDist
        local wasRange = proxPlayerWasInRange[player] or false
        if inRange then
            if not wasRange and Settings.ProximitySFXEnabled then playProximitySFX() end
            proxPlayerWasInRange[player] = true
            local cardData = getOrCreateCard(player)
            cardData.frame.Visible           = true
            local col = distanceToColor(dist, maxDist)
            cardData.accent.BackgroundColor3 = col
            cardData.distLabel.Text          = dist .. "m away"
            cardData.distLabel.TextColor3    = col
        else
            proxPlayerWasInRange[player] = false
            local cd = proximityCards[player]
            if cd then cd.frame.Visible = false end
        end
    end
end)

